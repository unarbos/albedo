ALBEDO_EVAL_DATABASE_URL=postgresql://albedo:albedo@localhost:5432/albedo
ALBEDO_EVAL_WORKER_ID=eval-dispatcher-local
ALBEDO_EVAL_REMOTE_AUTH_TOKEN=change-me
ALBEDO_EVAL_DATASET_VERSION=AlienKevin/SWE-ZERO-12M-trajectories
ALBEDO_EVAL_DATASET_MANIFEST_URI=s3://albedo-artifacts/datasets/swe-zero/manifest.json
ALBEDO_EVAL_DATASET_MANIFEST_HASH=982a92bd85d122d287b15f2ddb4e2050b9e345fb3921aa9a63382c7af022bd7f
# Optional local manifest path for dispatcher-side deterministic sample IDs.
# S3 manifest fetching is not implemented yet.
ALBEDO_EVAL_DATASET_MANIFEST_PATH=
ALBEDO_EVAL_SAMPLE_COUNT=128
ALBEDO_EVAL_MAX_TURNS_PER_SAMPLE=10
ALBEDO_EVAL_SAMPLING_ALGO=swe-zero-manifest-sample-v1
ALBEDO_EVAL_JUDGE_CONFIG_HASH=sha256:replace-with-real-hash
ALBEDO_EVAL_ARTIFACT_BUCKET=albedo-artifacts
ALBEDO_EVAL_ARTIFACT_PREFIX=s3://albedo-artifacts
ALBEDO_EVAL_LEASE_SECONDS=1800

# Remote eval smoke API settings
ALBEDO_REMOTE_AUTH_TOKEN=change-me
ALBEDO_REMOTE_HOST_ID=h200-smoke-1
ALBEDO_REMOTE_HOST_ROLE=EVAL
ALBEDO_REMOTE_GPU_COUNT=8
ALBEDO_REMOTE_FREE_GPU_COUNT=8
ALBEDO_REMOTE_ACCELERATOR_TYPE=H200
ALBEDO_REMOTE_READY=true
ALBEDO_REMOTE_MOCK_AUTO_VERDICT=true
ALBEDO_REMOTE_MOCK_CHALLENGER_WON=false
