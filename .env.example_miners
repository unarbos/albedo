# Albedo MINER configuration.
#
# Copy this file to `.env` (in the albedo repo root) and fill in your values:
#     cp .env.example_miners .env
#
# Every value here is optional — it just sets a default so you can omit the matching
# CLI flag. Real environment variables and CLI flags always override these
# (e.g. `CHAIN_NETWORK=test albedo check-commit` or `albedo commit --hotkey other`).

# --- Bittensor wallet -------------------------------------------------------
# Lets you run `albedo register / commit / publish` without --coldkey/--hotkey.
ALBEDO_COLDKEY=
ALBEDO_HOTKEY=
# Only set this if your wallets are NOT in the default ~/.bittensor/wallets dir.
# ALBEDO_WALLET_PATH=/home/you/.bittensor/wallets

# --- Subnet / chain ---------------------------------------------------------
CHAIN_NETUID=97
CHAIN_NETWORK=finney

# --- Hippius (model upload) -------------------------------------------------
# Use a token, OR a username + password (the token wins if both are set).
HIPPIUS_HUB_TOKEN=
# HIPPIUS_HUB_USERNAME=
# HIPPIUS_HUB_PASSWORD=

# --- Repo naming ------------------------------------------------------------
# Your Hippius namespace (the part before the slash). With this set you can omit
# --namespace; `--name v1` then builds `<namespace>/albedo-qwen3.6-35b-v1`.
ALBEDO_NAMESPACE=
# Leave the prefix as-is unless the subnet changes it.
ALBEDO_REPO_PREFIX=albedo-qwen3.6-35b

# --- Local cache ------------------------------------------------------------
# Where remote `check-hippius` downloads config.json for inspection.
# ALBEDO_MODEL_CACHE_DIR=/home/you/.cache/albedo_models
