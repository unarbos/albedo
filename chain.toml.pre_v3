[chain]
name         = "Albedo"
seed_repo    = "teutonic/albedo-qwen3-4b-genesis"
# Challengers must be named albedo-qwen3-4b-<suffix> under any Hippius namespace.
repo_pattern = "^[^/]+/albedo-qwen3-4b-.+$"

[arch]
module = "archs.qwen3"
extra_lock_keys = [
  # Architecture identity
  "max_position_embeddings",
  "tie_word_embeddings",
  "rope_theta",
  # Capacity keys — lock model to 4B size class (prevents submitting larger models)
  "hidden_size",
  "num_hidden_layers",
  "num_attention_heads",
  "num_key_value_heads",
  "intermediate_size",
  "head_dim",
]

[seed]
# Base Qwen3-4B from HuggingFace — upload via: python scripts/seed_genesis.py
#   --hf-model Qwen/Qwen3-4B --repo unarbos/albedo-qwen3-4b-genesis
# Then paste the returned sha256: digest below.
tokenizer_repo = "Qwen/Qwen3-4B"
seed_digest    = "sha256:3368b0c79b619ed90dc5610c20073cf02c3a93275ebc0c5b94a9d332fea6f606"

[judge]
models = [
  "deepseek-ai/DeepSeek-V3.2-TEE",
  "Qwen/Qwen3-235B-A22B-Thinking-2507",
  "moonshotai/Kimi-K2.6-TEE",
]
base_url_env        = "CHUTES_BASE_URL"
api_key_env         = "CHUTES_API_KEY"
temperature         = 0.0
max_tokens          = 256
# The five dimensions judged head-to-head per turn (S4 pairwise scoring).
metric_keys = ["correctness", "grounding", "progress", "protocol", "efficiency"]
# Score path (5-key JSON after a thinking preamble) needs more room than the probe path.
score_max_tokens    = 768
thinking_max_tokens = 4096
thinking_models = [
  "Qwen/Qwen3-235B-A22B-Thinking-2507",
  "moonshotai/Kimi-K2.6-TEE",
]
retry_max              = 3
retry_initial_backoff_s = 1.5
tie_band               = 0.01
# Hard ceiling on total time (seconds) spent retrying one judge call.
# When hit, the call returns parse_failure (score=0.0) so the duel can
# continue rather than stalling indefinitely on rate limits.
call_timeout_s         = 300.0
# Cap on wait time per 429 retry — prevents 4× backoff from reaching 384 s/attempt.
max_429_wait_s         = 60.0
# Bounded 429 retries on one call before giving up (→ parse_failure / fallback).
max_429_retries        = 8
# Default per-model request shaping (overridden per-model below).
max_concurrency_per_model = 6
min_interval_s_per_model  = 0.0
# --- Unified transport v2 (stream-gated Chutes -> batched OpenRouter) ---
chutes_try_s        = 2.0    # accept/reject gate: max wait for first streamed chunk
chutes_max_s        = 150.0  # max wait for an accepted Chutes stream to finish
or_timeout_s        = 150.0  # OpenRouter per-attempt timeout
or_retries          = 1      # OpenRouter retries (network/429/parse-fail)
judge_total_s       = 330.0  # per-judge OpenRouter-phase ceiling -> then unscored
chutes_giveup_tasks = 5      # circuit-breaker: dry tasks before OpenRouter-only

# Per-model request shaping — DeepSeek is the dominant 429 source on Chutes.
[judge.rate_limits]
"deepseek-ai/DeepSeek-V3.2-TEE"      = { max_concurrency = 1, min_interval_s = 2.0 }
"moonshotai/Kimi-K2.6-TEE"           = { max_concurrency = 2, min_interval_s = 2.0 }
"Qwen/Qwen3-235B-A22B-Thinking-2507" = { max_concurrency = 4, min_interval_s = 0.0 }

# Fallback provider: on a Chutes 429 (beyond chutes_429_grace_s) re-issue the call here.
[judge.fallback]
enabled          = true
base_url         = "https://openrouter.ai/api"  # client appends /v1/chat/completions
api_key_env      = "OPENROUTER_API_KEY"
chutes_429_grace_s = 4.0
reasoning_models = ["Qwen/Qwen3-235B-A22B-Thinking-2507", "moonshotai/Kimi-K2.6-TEE"]
[judge.fallback.model_map]
"deepseek-ai/DeepSeek-V3.2-TEE"      = "deepseek/deepseek-v3.2"
"moonshotai/Kimi-K2.6-TEE"           = "moonshotai/kimi-k2.6"
"Qwen/Qwen3-235B-A22B-Thinking-2507" = "qwen/qwen3-235b-a22b-thinking-2507"

[dataset]
repo        = "AlienKevin/SWE-ZERO-12M-trajectories"
shard_glob  = "data/train-*.parquet"
manifest_sha256 = "982a92bd85d122d287b15f2ddb4e2050b9e345fb3921aa9a63382c7af022bd7f"

[duel]
n_samples            = 64
max_turns_per_sample = 10
alpha                = 0.001
gate_alpha           = 0.05
bootstrap_resamples  = 10000
gen_temperature      = 1.0
gen_max_tokens       = 1024
gen_max_model_len    = 32768
king_chain_depth     = 5
# Soft wall-budget: stop launching new turns past this, finalize on completed turns
# (just below the validator hard-timeout of 12000s).
duel_budget_s        = 11000.0
# S4 acceptance: crown only if (challenger_score - king_score) >= win_margin (0–100 scale).
win_margin           = 2.0
min_valid_turn_frac  = 0.5

[preeval]
similarity_threshold = 0.95
