"""albedo.validator.challenge — Single challenge dispatch."""
from __future__ import annotations

import asyncio
import hashlib
import json
import logging
import os
import time
from typing import TYPE_CHECKING

import httpx

from albedo.validator.admission import validate_challenger_config
from albedo.validator.faults import is_infra_failure, is_miner_fault
from albedo.validator.weights import maybe_set_weights

NETUID: int = int(os.environ.get("ALBEDO_NETUID", "0"))

if TYPE_CHECKING:
    from albedo.storage import State

log = logging.getLogger(__name__)

_TIME_BUCKET_S: int = 600  # 10-minute fallback seed bucket
# Per-event idle limits on the /eval SSE stream: warn periodically, kill a truly
# stalled stream so a hung eval is caught in minutes rather than the tick timeout.
_STREAM_IDLE_WARN_S:  float = float(os.environ.get("ALBEDO_STREAM_IDLE_WARN_S", "600"))
_STREAM_IDLE_KILL_S:  float = float(os.environ.get("ALBEDO_STREAM_IDLE_KILL_S", "1800"))


def _compute_seed(subtensor: object, hotkey: str, reveal_block: int | None = None) -> bytes:
    """Return blake2b(block_hash_at_reveal_block || hotkey).

    Falls back to subtensor.block, then a 10-minute time-bucket on RPC failure.
    Probe seed is kept distinct from duel seed by using the reveal block hash.
    """
    if reveal_block is None:
        try:
            reveal_block = int(subtensor.block)
        except Exception as exc:
            log.warning("_compute_seed: subtensor.block failed: %s — using time bucket", exc)

    block_hash: str | None = None
    if reveal_block is not None:
        try:
            block_hash = subtensor.get_block_hash(reveal_block)
        except Exception as exc:
            log.warning("_compute_seed: get_block_hash(%s) failed: %s", reveal_block, exc)

    if block_hash is None:
        bucket = int(time.time()) // _TIME_BUCKET_S * _TIME_BUCKET_S
        block_hash = f"time-bucket-{bucket}"
        log.warning("_compute_seed: time-bucket seed %s  hotkey=%s", block_hash, hotkey)

    return hashlib.blake2b(block_hash.encode() + hotkey.encode()).digest()


async def _eval_set_king(http: httpx.AsyncClient, king: dict, eval_url: str) -> None:
    """POST /set_king to eval server; raises on HTTP error.

    Endpoint expects: {"king": {"repo": str, "digest": str}}
    KingEntry.to_dict() uses "model_repo"/"model_digest" so we remap here.
    """
    url = eval_url.rstrip("/") + "/set_king"
    body = {"king": {"repo": king["model_repo"], "digest": king["model_digest"]}}
    resp = await http.post(url, json=body, timeout=30.0)
    resp.raise_for_status()


async def _stream_verdict(
    http: httpx.AsyncClient, url: str, payload: dict, state: "State", entry: dict,
) -> tuple[dict | None, bool, str]:
    """POST url and read SSE until a verdict event; returns (verdict|None, infra_failure, detail).

    Kills a stalled stream after _STREAM_IDLE_KILL_S with no event, and forwards
    start/turn progress to current_eval so the dashboard shows the live duel.
    """
    try:
        async with http.stream("POST", url, json=payload, timeout=None) as resp:
            if resp.status_code != 200:
                return None, True, f"HTTP {resp.status_code} from /eval"

            # Read lines in a background task feeding a queue so the per-event idle
            # timeout (below) can fire without cancelling — and breaking — the iterator.
            queue: asyncio.Queue = asyncio.Queue()

            async def _reader() -> None:
                try:
                    async for ln in resp.aiter_lines():
                        await queue.put(("line", ln))
                    await queue.put(("eof", None))
                except Exception as exc:  # noqa: BLE001 — surfaced to the consumer
                    await queue.put(("err", exc))

            reader = asyncio.create_task(_reader())
            try:
                event_type = ""
                n_done = 0
                idle = 0.0
                while True:
                    try:
                        kind, val = await asyncio.wait_for(queue.get(), timeout=_STREAM_IDLE_WARN_S)
                        idle = 0.0
                    except asyncio.TimeoutError:
                        idle += _STREAM_IDLE_WARN_S
                        if idle >= _STREAM_IDLE_KILL_S:
                            return None, True, f"eval stream idle > {_STREAM_IDLE_KILL_S:.0f}s"
                        log.warning("eval stream idle %.0fs (kill at %.0fs) — eval_id=%s",
                                    idle, _STREAM_IDLE_KILL_S, entry.get("eval_id"))
                        continue

                    if kind == "eof":
                        break
                    if kind == "err":
                        if isinstance(val, httpx.RequestError):
                            return None, True, f"connection error streaming /eval: {val}"
                        return None, True, f"error streaming /eval: {val}"

                    line = val.rstrip()
                    if line.startswith("event:"):
                        event_type = line[len("event:"):].strip()
                    elif line.startswith("data:"):
                        try:
                            data = json.loads(line[len("data:"):].strip())
                        except Exception:
                            continue
                        if event_type == "verdict":
                            return data, False, ""
                        if state.current_eval is not None:
                            if event_type == "start":
                                state.current_eval.update(
                                    {"phase": "duel", "n_total": data.get("n_samples", 0), "n_done": 0})
                                state.flush_dashboard()
                            elif event_type == "turn":
                                n_done += 1
                                state.current_eval.update(
                                    {"n_done": n_done, "mean_delta": data.get("delta_avg", 0.0)})
                                state.flush_dashboard()
                    elif line == "":
                        event_type = ""
            finally:
                reader.cancel()
    except httpx.RequestError as exc:
        return None, True, f"connection error streaming /eval: {exc}"
    return None, True, "no verdict received from /eval stream"


async def process_challenge(
    state: "State",
    http: httpx.AsyncClient,
    subtensor: object,
    wallet: object,
    entry: dict,
    eval_url: str,
) -> str:
    """Run one challenger through admission → seed → /eval SSE → verdict.

    Returns an outcome tag: "crowned" | "rejected" | "duplicate" | "miner_fault"
    | "infra" | "skip". The caller backs off the eval box on "infra".
    close_eval() is always called in the finally block to release the eval slot.
    """
    hotkey = entry.get("hotkey", "")
    model_repo = entry.get("model_repo", "")
    model_digest = entry.get("model_digest", "")
    eval_id = entry.get("eval_id", "")

    log.info(
        "EVAL START  %s — hotkey=%s  repo=%s",
        eval_id, hotkey, model_repo,
    )

    state.current_eval = entry
    state.flush_dashboard()

    king = state.king
    if king is None:
        log.warning("EVAL %s — no king set, skipping hotkey=%s", eval_id, hotkey)
        state.close_eval()
        return "skip"

    log.info("EVAL %s — admission check: repo=%s  king=%s", eval_id, model_repo, king.model_repo)
    rejection = validate_challenger_config(
        model_repo=model_repo,
        challenger_digest=model_digest,
        king_repo=king.model_repo,
        king_digest=king.model_digest,
    )
    if rejection is not None:
        if is_miner_fault("admission_rejected", rejection):
            log.info("EVAL %s — ADMISSION REJECTED (terminal)  hotkey=%s  reason=%s",
                     eval_id, hotkey, rejection)
            state.record_failure(entry, "admission_rejected", rejection)
            state.close_eval()
            return "miner_fault"
        log.warning("EVAL %s — admission transient failure, retrying  hotkey=%s  reason=%s",
                    eval_id, hotkey, rejection)
        state.record_failure(entry, "infra_failure", rejection)
        state.unburn(entry)
        state.close_eval()
        return "infra"

    log.info("EVAL %s — admission passed, dispatching to GPU  hotkey=%s  repo=%s  vs king=%s",
             eval_id, hotkey, model_repo, king.model_repo)
    seed = _compute_seed(subtensor, hotkey, entry.get("block"))
    eval_payload = {
        # Field names must match EvalRequest in eval_server/endpoints.py exactly.
        "eval_id":    eval_id,
        "hotkey":     hotkey,
        "seed_hex":   seed.hex(),          # was "seed" — Pydantic requires "seed_hex"
        "king": {
            "repo":   king.model_repo,     # was "model_repo"
            "digest": king.model_digest,   # was "model_digest"
        },
        "challenger": {
            "repo":   model_repo,          # was missing entirely
            "digest": model_digest,
        },
    }

    verdict, infra_failure, infra_detail = await _stream_verdict(
        http, eval_url.rstrip("/") + "/eval", eval_payload, state, entry
    )

    try:
        if infra_failure:
            log.error("process_challenge: infra failure — %s", infra_detail)
            state.record_failure(entry, "infra_failure", infra_detail)
            state.unburn(entry)
            return "infra"

        # A duplicate verdict carries both is_duplicate and an error string — classify
        # it as a duplicate (most specific) before the generic error branch.
        if bool(verdict.get("is_duplicate", False)):   # type: ignore[union-attr]
            state.record_failure(entry, "duplicate", verdict.get("duplicate_of", ""))
            log.info("process_challenge: duplicate — %s  repo=%s", hotkey, model_repo)
            return "duplicate"

        # An eval-server error verdict (e.g. challenger vLLM crash, injection): classify
        # miner-fault (terminal) vs transient (retry) before the dethrone logic.
        err = verdict.get("error")
        if err:
            if is_miner_fault("challenger_rejected", err):
                log.info("process_challenge: challenger rejected (terminal) %s — %s", hotkey, err)
                state.record_failure(entry, "challenger_rejected", err)
                return "miner_fault"
            log.warning("process_challenge: eval error (transient), retrying %s — %s", hotkey, err)
            state.record_failure(entry, "infra_failure", err)
            state.unburn(entry)
            return "infra"

        # No completed turns is an infra issue, not a fair loss — retry it.
        if is_infra_failure(verdict):
            log.warning("process_challenge: no valid turns — infra, retrying %s", hotkey)
            state.record_failure(entry, "infra_failure",
                                 f"no valid turns (n_done={verdict.get('n_done')})")
            state.unburn(entry)
            return "infra"

        accepted   = bool(verdict.get("accepted", False))
        mean_delta = float(verdict.get("mean_delta", 0.0))
        gate_lcb   = float(verdict.get("gate_lcb", 0.0))
        chal_score = float(verdict.get("challenger_score", 0.0))
        king_score = float(verdict.get("king_score", 0.0))
        log.info(
            "EVAL %s — VERDICT: %s  hotkey=%s  repo=%s  "
            "score=%.2f vs %.2f  delta=%.4f  lcb=%.4f",
            eval_id,
            "ACCEPTED ✓" if accepted else "REJECTED ✗",
            hotkey, model_repo,
            chal_score, king_score,
            mean_delta, gate_lcb,
        )

        if accepted:
            state.record_verdict(entry, verdict)
            log.info(
                "EVAL %s — NEW KING: hotkey=%s  repo=%s  dethroned=%s",
                eval_id, hotkey, model_repo,
                king.model_repo if king else "none",
            )
            # Record which judges crowned the new king. The current eval verdict
            # carries them under "by_judge" (older shape used "judges").
            crown_judges = list((verdict.get("by_judge") or verdict.get("judges") or {}).keys())
            # block is None for current-format (dict) commitments; coerce to 0 so
            # KingEntry's int validator doesn't raise and silently abort the crown.
            state.set_king(
                hotkey=hotkey, model_repo=model_repo, model_digest=model_digest,
                block=entry.get("block") or 0, challenge_id=eval_id,
                dethrone_judges=crown_judges,
                crown_judges=crown_judges,
            )
            try:
                await _eval_set_king(http, state.king.to_dict(), eval_url)
            except Exception as exc:
                log.warning("process_challenge: _eval_set_king failed: %s", exc)
            await maybe_set_weights(subtensor, wallet, state, netuid=NETUID, force=True, reason="new king")
            return "crowned"
        state.record_verdict(entry, verdict)
        return "rejected"
    finally:
        # Always release eval slot, even on exception
        state.close_eval()
