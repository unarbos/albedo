"""albedo.judge.client — Async LLM-as-judge client (Chutes primary, OpenRouter fallback)."""
from __future__ import annotations

import asyncio
import json
import logging
import os
import re
from typing import Any

import httpx

import random
import time

from albedo.config import (
    JUDGE_API_KEY_ENV,
    JUDGE_BASE_URL_ENV,
    JUDGE_CALL_TIMEOUT_S,
    JUDGE_MAX_TOKENS,
    JUDGE_METRIC_KEYS,
    JUDGE_RETRY_BACKOFF,
    JUDGE_RETRY_MAX,
    JUDGE_SCORE_MAX_TOKENS,
    JUDGE_TEMPERATURE,
    JUDGE_THINKING_MODELS,
    JUDGE_THINKING_TOKENS,
    JUDGE_429_MAX_WAIT_S,
    JUDGE_429_MAX_RETRIES,
    JUDGE_MAX_CONCURRENCY_PER_MODEL,
    JUDGE_MIN_INTERVAL_S_PER_MODEL,
    JUDGE_RATE_LIMITS,
    JUDGE_FALLBACK_ENABLED,
    JUDGE_FALLBACK_BASE_URL,
    JUDGE_FALLBACK_API_KEY_ENV,
    JUDGE_FALLBACK_MODEL_MAP,
    JUDGE_FALLBACK_REASONING_MODELS,
    JUDGE_CHUTES_429_GRACE_S,
    DUEL_DEADLINE_S,
)
from albedo.judge.rubric import PAIRWISE_RUBRIC_SYSTEM, PROBE_SYSTEM, build_pairwise_user
from albedo.judge.verdict import MetricVerdict, parse_metric_verdict

log = logging.getLogger(__name__)

_DEFAULT_BASE_URL = "https://llm.chutes.ai"

_CHUTES     = "chutes"
_OPENROUTER = "openrouter"


class DeadlineExceeded(RuntimeError):
    """Raised when a judge call exhausts its total time budget.

    Caught by pairwise_judge() and converted to a parse_failure MetricVerdict so
    the duel turn continues with score=0.0 rather than the whole turn being aborted.
    """


class _ChutesUnavailable(Exception):
    """Internal: Chutes is rate-limited/erroring past its grace → trigger OpenRouter fallback."""


def _is_thinking(model: str) -> bool:
    return model in JUDGE_THINKING_MODELS


def _merge_thinking(choices: list[dict]) -> str:
    """Concatenate reasoning_content + content from the first choice."""
    if not choices:
        return ""
    msg = choices[0].get("message", {})
    reasoning = msg.get("reasoning_content") or msg.get("reasoning") or ""
    content   = msg.get("content") or ""
    if reasoning:
        return f"{reasoning}\n{content}"
    return content


class ChutesJudge:
    """Async LLM-as-judge client; one instance per duel, shared across all judge models.

    Primary provider is Chutes. On a Chutes 429 (beyond a short grace) the same call is
    re-issued to OpenRouter so rate limits never stall the duel. Per-model concurrency +
    spacing keeps Chutes 429s low; a whole-duel deadline caps total wall time.
    """

    def __init__(
        self,
        *,
        base_url: str | None = None,
        api_key:  str | None = None,
    ) -> None:
        self._base_url = (
            base_url
            or os.environ.get(JUDGE_BASE_URL_ENV, "")
            or _DEFAULT_BASE_URL
        ).rstrip("/")
        self._api_key = api_key or os.environ.get(JUDGE_API_KEY_ENV, "")
        headers = {"Authorization": f"Bearer {self._api_key}"}
        # Separate timeouts per model class: thinking models (Qwen3-235B, Kimi-K2.6)
        # regularly need 300–600 s for reasoning traces; regular models are fast.
        self._client       = httpx.AsyncClient(
            base_url=self._base_url, headers=headers,
            timeout=httpx.Timeout(connect=10.0, read=150.0, write=30.0, pool=10.0),
        )
        self._think_client = httpx.AsyncClient(
            base_url=self._base_url, headers=headers,
            timeout=httpx.Timeout(connect=10.0, read=600.0, write=30.0, pool=10.0),
        )

        # OpenRouter fallback clients (only built when enabled and a key is present).
        self._fb_key = os.environ.get(JUDGE_FALLBACK_API_KEY_ENV, "")
        self._fb_enabled = bool(JUDGE_FALLBACK_ENABLED and self._fb_key)
        self._fb_client = self._fb_think_client = None
        if self._fb_enabled:
            fb_headers = {"Authorization": f"Bearer {self._fb_key}"}
            fb_base = JUDGE_FALLBACK_BASE_URL.rstrip("/")
            self._fb_client = httpx.AsyncClient(
                base_url=fb_base, headers=fb_headers,
                timeout=httpx.Timeout(connect=10.0, read=150.0, write=30.0, pool=10.0),
            )
            self._fb_think_client = httpx.AsyncClient(
                base_url=fb_base, headers=fb_headers,
                timeout=httpx.Timeout(connect=10.0, read=600.0, write=30.0, pool=10.0),
            )

        # Per-(provider,model) pacing state — created lazily inside the running loop.
        self._sems:        dict[str, asyncio.Semaphore] = {}
        self._sched_locks: dict[str, asyncio.Lock]      = {}
        self._next_at:     dict[str, float]             = {}

        # Whole-duel wall budget (this instance lives for exactly one duel).
        self._duel_deadline = time.monotonic() + DUEL_DEADLINE_S

    # ----- per-model pacing helpers (lazy, single-threaded asyncio so no extra lock) -----

    def _limits(self, model: str) -> tuple[int, float]:
        rl = JUDGE_RATE_LIMITS.get(model, {})
        return (
            int(rl.get("max_concurrency", JUDGE_MAX_CONCURRENCY_PER_MODEL)),
            float(rl.get("min_interval_s", JUDGE_MIN_INTERVAL_S_PER_MODEL)),
        )

    async def _acquire_slot(self, key: str, max_concurrency: int, interval: float) -> asyncio.Semaphore:
        sem = self._sems.get(key)
        if sem is None:
            sem = self._sems[key] = asyncio.Semaphore(max(1, max_concurrency))
        await sem.acquire()
        if interval > 0:
            lock = self._sched_locks.get(key)
            if lock is None:
                lock = self._sched_locks[key] = asyncio.Lock()
            async with lock:
                now  = time.monotonic()
                wait = max(0.0, self._next_at.get(key, 0.0) - now)
                self._next_at[key] = max(now, self._next_at.get(key, 0.0)) + interval
            if wait:
                await asyncio.sleep(wait)
        return sem

    def _or_model(self, model: str) -> str | None:
        return JUDGE_FALLBACK_MODEL_MAP.get(model)

    def _clients(self, provider: str, thinking: bool):
        if provider == _OPENROUTER:
            return self._fb_think_client if thinking else self._fb_client
        return self._think_client if thinking else self._client

    def _payload(self, provider: str, model: str, messages: list[dict], max_tokens: int) -> dict[str, Any]:
        if provider == _OPENROUTER:
            payload: dict[str, Any] = {
                "model":       self._or_model(model) or model,
                "messages":    messages,
                "temperature": JUDGE_TEMPERATURE,
                "max_tokens":  max_tokens,
            }
            if model in JUDGE_FALLBACK_REASONING_MODELS:
                payload["reasoning"] = {"enabled": True}
            return payload
        return {
            "model":       model,
            "messages":    messages,
            "temperature": JUDGE_TEMPERATURE,
            "max_tokens":  max_tokens,
        }

    # ----- core call path -----

    async def _chat(
        self,
        messages: list[dict],
        *,
        model: str,
        max_tokens: int,
        deadline: float,
    ) -> list[dict]:
        """POST /v1/chat/completions: try Chutes, fall back to OpenRouter on rate-limit.

        - Chutes 429s are tolerated only for ~JUDGE_CHUTES_429_GRACE_S; past that (or on a
          Chutes 4xx/5xx failure) the same call is re-issued to OpenRouter instead of waiting.
        - 429 backoff honors Retry-After + jitter; retries are bounded by JUDGE_429_MAX_RETRIES.
        - DeadlineExceeded fires when neither provider answers within `deadline`.
        """
        try:
            return await self._call(
                _CHUTES, messages, model=model, max_tokens=max_tokens, deadline=deadline
            )
        except _ChutesUnavailable as exc:
            if self._fb_enabled and self._or_model(model):
                log.warning("Judge %s: Chutes unavailable (%s) — falling back to OpenRouter", model, exc)
                return await self._call(
                    _OPENROUTER, messages, model=model, max_tokens=max_tokens, deadline=deadline
                )
            raise DeadlineExceeded(f"Judge {model}: Chutes unavailable, no fallback ({exc})")

    async def _call(
        self,
        provider: str,
        messages: list[dict],
        *,
        model: str,
        max_tokens: int,
        deadline: float,
    ) -> list[dict]:
        thinking = _is_thinking(model)
        client   = self._clients(provider, thinking)
        if client is None:
            raise _ChutesUnavailable("fallback client unavailable")
        payload = self._payload(provider, model, messages, max_tokens)

        if provider == _CHUTES:
            max_concurrency, interval = self._limits(model)
        else:
            max_concurrency, interval = JUDGE_MAX_CONCURRENCY_PER_MODEL, 0.0
        key = f"{provider}:{model}"

        # Small pre-call jitter so king & challenger calls to the same judge don't collide.
        first_jitter = random.uniform(0.0, 0.5)
        if time.monotonic() + first_jitter < deadline:
            await asyncio.sleep(first_jitter)

        n_429 = 0
        n_err = 0
        chutes_429_wait = 0.0
        last_exc: Exception | None = None

        while True:
            if time.monotonic() >= deadline:
                if provider == _CHUTES:
                    raise _ChutesUnavailable(f"deadline reached ({n_429} 429, {n_err} errors)")
                raise DeadlineExceeded(
                    f"Judge {model} deadline exceeded on {provider} ({n_429} 429, {n_err} errors)"
                )

            status: int | None = None
            retry_after: str | None = None
            sem = await self._acquire_slot(key, max_concurrency, interval)
            try:
                resp = await client.post("/v1/chat/completions", json=payload)
                resp.raise_for_status()
                return resp.json().get("choices", [])
            except httpx.HTTPStatusError as exc:
                status = exc.response.status_code
                last_exc = exc
                if status == 429:
                    retry_after = exc.response.headers.get("Retry-After")
                elif status < 500:
                    # Permanent client error: bail to fallback (Chutes) or give up (OpenRouter).
                    if provider == _CHUTES:
                        raise _ChutesUnavailable(f"HTTP {status}")
                    raise DeadlineExceeded(f"Judge {model} HTTP {status} on {provider}")
            except (_ChutesUnavailable, DeadlineExceeded):
                raise
            except Exception as exc:  # network / timeout → treat as server error
                last_exc = exc
            finally:
                sem.release()

            if status == 429:
                n_429 += 1
                try:
                    raw_wait = max(float(retry_after), 1.0) if retry_after else \
                        JUDGE_RETRY_BACKOFF * (4 ** min(n_429 - 1, 4))
                except ValueError:
                    raw_wait = JUDGE_RETRY_BACKOFF * (4 ** min(n_429 - 1, 4))
                wait = min(raw_wait, JUDGE_429_MAX_WAIT_S) * random.uniform(0.8, 1.3)

                if provider == _CHUTES and self._fb_enabled and self._or_model(model):
                    # Tolerate only a short grace of Chutes throttling, then fall back.
                    if chutes_429_wait + wait > JUDGE_CHUTES_429_GRACE_S:
                        raise _ChutesUnavailable(f"429 past {JUDGE_CHUTES_429_GRACE_S:.0f}s grace")
                    chutes_429_wait += wait

                if n_429 > JUDGE_429_MAX_RETRIES:
                    if provider == _CHUTES:
                        raise _ChutesUnavailable("429 retries exhausted")
                    raise DeadlineExceeded(f"Judge {model} 429 retries exhausted on {provider}")

                wait = min(wait, max(0.0, deadline - time.monotonic()))
                log.warning("Judge %s 429 (#%d, %s) — waiting %.1fs", model, n_429, provider, wait)
                if wait > 0:
                    await asyncio.sleep(wait)
                continue

            # non-429 error path (5xx / network)
            n_err += 1
            if n_err >= JUDGE_RETRY_MAX:
                if provider == _CHUTES:
                    raise _ChutesUnavailable(f"{n_err} errors: {last_exc}")
                raise DeadlineExceeded(
                    f"Judge {model} failed after {n_err} errors on {provider}: {last_exc}"
                )
            backoff = min(
                JUDGE_RETRY_BACKOFF * (2 ** (n_err - 1)),
                max(0.1, deadline - time.monotonic() - 0.1),
            ) * random.uniform(0.8, 1.3)
            log.warning(
                "Judge %s error (%d/%d, %s): %s — retry in %.1fs",
                model, n_err, JUDGE_RETRY_MAX, provider, last_exc, backoff,
            )
            await asyncio.sleep(max(0.0, backoff))

    def _build_pairwise_messages(
        self,
        context_messages: list[dict],
        king_reply: str,
        chal_reply: str,
    ) -> list[dict]:
        return [
            {"role": "system", "content": PAIRWISE_RUBRIC_SYSTEM},
            {"role": "user",   "content": build_pairwise_user(
                context_messages, king_reply, chal_reply)},
        ]

    def _build_probe_messages(
        self,
        messages: list[dict],
        reply: str,
    ) -> list[dict]:
        combined = json.dumps(
            {
                "conversation": messages,
                "candidate_reply": reply,
            },
            ensure_ascii=False,
        )
        return [
            {"role": "system", "content": PROBE_SYSTEM},
            {"role": "user",   "content": combined},
        ]

    async def pairwise_judge(
        self,
        context_messages: list[dict] | None = None,
        king_reply: str = "",
        chal_reply: str = "",
        *,
        model: str,
        messages_prefix: list[dict] | None = None,
        messages_prompt: list[dict] | None = None,
        hotkey: str = "",
        seed: bytes = b"",
    ) -> MetricVerdict:
        """Score one turn head-to-head (MODEL 1 = king, MODEL 2 = challenger).

        Accepts either context_messages or messages_prefix + messages_prompt
        (the form used by turn.py). One judge call returns per-metric scores
        in challenger perspective.

        Returns a parse_failure MetricVerdict (all-zero, judge_mean=0.0) when the
        call exceeds its deadline (capped at the whole-duel budget) — the duel
        continues rather than stalling.
        """
        if context_messages is None:
            context_messages = list(messages_prefix or []) + list(messages_prompt or [])

        thinking   = _is_thinking(model)
        max_tokens = JUDGE_THINKING_TOKENS if thinking else JUDGE_SCORE_MAX_TOKENS
        # Cap each call's budget at the whole-duel deadline so one duel can't overrun.
        deadline   = min(time.monotonic() + JUDGE_CALL_TIMEOUT_S, self._duel_deadline)

        messages = self._build_pairwise_messages(context_messages, king_reply, chal_reply)
        try:
            choices = await self._chat(
                messages, model=model, max_tokens=max_tokens, deadline=deadline
            )
            raw = _merge_thinking(choices)
        except DeadlineExceeded:
            log.warning(
                "Judge %s score deadline exceeded — returning parse_failure", model,
            )
            return MetricVerdict(
                metric_scores={k: 0.0 for k in JUDGE_METRIC_KEYS},
                judge_mean=0.0, raw="", parse_ok=False, model=model,
            )

        verdict       = parse_metric_verdict(raw)
        verdict.model = model
        return verdict

    async def probe(
        self,
        messages: list[dict],
        reply: str,
        *,
        model: str,
    ) -> tuple[bool, str]:
        """Injection probe; returns (is_injected, evidence).

        Uses PROBE_SYSTEM to check whether the reply contains injection patterns.
        Retries indefinitely on transient errors — callers must always receive a
        definitive answer (True/False) and must never silently skip the probe.

        Schema: {"injection": true|false, "evidence": "<snippet or 'none'>"}
        """
        thinking   = _is_thinking(model)
        max_tokens = JUDGE_THINKING_TOKENS if thinking else JUDGE_MAX_TOKENS

        probe_messages = self._build_probe_messages(messages, reply)
        probe_re       = re.compile(
            r'\{[^{}]*"injection"\s*:\s*(?:true|false)[^{}]*\}', re.DOTALL
        )

        attempt = 0
        while True:
            # Probe uses a fresh deadline per attempt — probes must always complete.
            deadline = time.monotonic() + JUDGE_CALL_TIMEOUT_S
            try:
                choices = await self._chat(
                    probe_messages, model=model, max_tokens=max_tokens, deadline=deadline
                )
                raw = _merge_thinking(choices)
            except Exception as exc:
                attempt += 1
                wait = min(JUDGE_RETRY_BACKOFF * (2 ** min(attempt - 1, 6)), 120.0)
                log.warning(
                    "probe: judge %s error (attempt %d) — retrying in %.0fs: %s",
                    model, attempt, wait, exc,
                )
                await asyncio.sleep(wait)
                continue

            def _extract(data: dict) -> tuple[bool, str]:
                is_injected = bool(data.get("injection", False))
                evidence = str(data.get("evidence") or data.get("reason") or "").strip()
                if evidence.lower() == "none":
                    evidence = ""
                return is_injected, evidence

            matches = probe_re.findall(raw)
            if matches:
                try:
                    return _extract(json.loads(matches[-1]))
                except json.JSONDecodeError:
                    pass

            stripped = raw.strip()
            if stripped.startswith("{"):
                try:
                    return _extract(json.loads(stripped))
                except json.JSONDecodeError:
                    pass

            # Judge responded but output was unparseable — retry to get a valid JSON.
            attempt += 1
            wait = min(JUDGE_RETRY_BACKOFF * (2 ** min(attempt - 1, 4)), 60.0)
            log.warning(
                "probe: judge %s returned unparseable output (attempt %d) "
                "— retrying in %.0fs: %r",
                model, attempt, wait, raw[:200],
            )
            await asyncio.sleep(wait)

    async def aclose(self) -> None:
        await self._client.aclose()
        await self._think_client.aclose()
        if self._fb_client is not None:
            await self._fb_client.aclose()
        if self._fb_think_client is not None:
            await self._fb_think_client.aclose()

    async def __aenter__(self) -> "ChutesJudge":
        return self

    async def __aexit__(self, *_: object) -> None:
        await self.aclose()
